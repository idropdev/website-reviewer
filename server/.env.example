# ─────────────────────────────────────────────────────────────────────────────
# Website Reviewer — Server Environment Variables
# Copy this file to .env and fill in your values. NEVER commit the .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080

# Set to 'production' in your deployment environment
NODE_ENV=development

# ─── AI Provider ─────────────────────────────────────────────────────────────
# Google Gemini API key — https://aistudio.google.com/app/apikey
# If no key is provided, the app falls back to deterministic simulation scoring.
GEMINI_API_KEY=

# ─── Scraper Tuning ──────────────────────────────────────────────────────────
# Puppeteer page load timeout in milliseconds (default: 25000)
PUPPETEER_TIMEOUT_MS=25000

# Maximum visible text characters to extract per page (default: 30000)
MAX_TEXT_CHARS=30000

# ─── CORS / Origins ──────────────────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call this API.
# In production, set this to your deployed frontend URL.
# Example: ALLOWED_ORIGINS=https://yourapp.vercel.app,https://yoursite.com
# In development, localhost:5173 / localhost:4173 / localhost:3000 are always allowed.
ALLOWED_ORIGINS=

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Global limit: max requests per IP across all /api/* routes
RATE_LIMIT_GLOBAL_MAX=120
RATE_LIMIT_GLOBAL_WINDOW_MINUTES=15

# Scan limit: max scan requests per IP (each scan runs Puppeteer + AI — expensive)
RATE_LIMIT_SCAN_MAX=8
RATE_LIMIT_SCAN_WINDOW_MINUTES=10

# ─── Proxy / Deployment ──────────────────────────────────────────────────────
# Set to 'false' if running without a reverse proxy (no Cloud Run / Render / Nginx).
# When 'true', Express trusts X-Forwarded-For for accurate IP detection.
TRUST_PROXY=true
